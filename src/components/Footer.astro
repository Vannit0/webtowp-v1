---
import { Github, Linkedin, Twitter, Mail } from 'lucide-react';
---

<footer class="bg-slate-900 text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="col-span-1 md:col-span-2">
        <img src="/logo-webtowp.png" alt="WebToWP" class="h-20 w-auto mb-4" />
        <p class="text-slate-400 mb-6 max-w-md">
          Agencia especializada en desarrollo web con WordPress Headless y Astro.
          Creamos experiencias digitales rápidas, seguras y escalables.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-slate-800 hover:bg-slate-700 flex items-center justify-center transition-colors">
            <Github className="w-5 h-5" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-slate-800 hover:bg-slate-700 flex items-center justify-center transition-colors">
            <Linkedin className="w-5 h-5" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-slate-800 hover:bg-slate-700 flex items-center justify-center transition-colors">
            <Twitter className="w-5 h-5" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-slate-800 hover:bg-slate-700 flex items-center justify-center transition-colors">
            <Mail className="w-5 h-5" />
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-semibold text-lg mb-4">Servicios</h4>
        <ul class="space-y-3">
          <li>
            <a href="#" class="text-slate-400 hover:text-white transition-colors">Landing Pages</a>
          </li>
          <li>
            <a href="#" class="text-slate-400 hover:text-white transition-colors">Sitios Informativos</a>
          </li>
          <li>
            <a href="#" class="text-slate-400 hover:text-white transition-colors">Optimización WP</a>
          </li>
          <li>
            <a href="#" class="text-slate-400 hover:text-white transition-colors">Migración Headless</a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-lg mb-4">Empresa</h4>
        <ul class="space-y-3">
          <li>
            <a href="#" class="text-slate-400 hover:text-white transition-colors">Sobre nosotros</a>
          </li>
          <li>
            <a href="#" class="text-slate-400 hover:text-white transition-colors">Proyectos</a>
          </li>
          <li>
            <a href="#" class="text-slate-400 hover:text-white transition-colors">Blog</a>
          </li>
          <li>
            <a href="#" class="text-slate-400 hover:text-white transition-colors">Contacto</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-slate-400 text-sm">
          © 2024 WebToWP. Todos los derechos reservados.
        </p>
        <div class="flex gap-6 text-sm">
          <a href="#" class="text-slate-400 hover:text-white transition-colors">
            Política de Privacidad
          </a>
          <a href="#" class="text-slate-400 hover:text-white transition-colors">
            Términos de Servicio
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
