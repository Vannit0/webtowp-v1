---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SmoothScroll from '../components/SmoothScroll';
import FloatingOrbs from '../components/FloatingOrbs';
import ContactForm from '../components/ContactForm';
---

<Layout 
  title="Contacto - WebToWP | Hablemos de tu Proyecto"
  description="¿Listo para transformar tu presencia digital? Contáctanos y descubre cómo podemos ayudarte con WordPress Headless y Astro."
>
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10 min-h-screen">
    <section class="relative overflow-hidden pt-32 pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 backdrop-blur-xl border border-white/60 shadow-lg shadow-slate-200/50 text-slate-700 text-sm font-medium mb-6">
            <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span>Estamos aquí para ayudarte</span>
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
            Hablemos de
            <br />
            <span class="bg-gradient-to-r from-cyan-500 via-purple-500 to-violet-600 bg-clip-text text-transparent">
              tu próximo proyecto
            </span>
          </h1>

          <p class="text-lg md:text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
            Transformemos tu visión en una experiencia web excepcional.
            Cuéntanos sobre tu proyecto y te mostraremos cómo podemos ayudarte.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div class="space-y-8">
            <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300">
              <div class="flex items-start gap-4 group cursor-pointer">
                <div class="flex-shrink-0 w-14 h-14 bg-gradient-to-r from-cyan-500 to-cyan-600 rounded-xl flex items-center justify-center shadow-lg shadow-cyan-500/30 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-cyan-500 group-hover:to-cyan-600 group-hover:bg-clip-text transition-all duration-300">
                    Email
                  </h3>
                  <a href="mailto:hola@webtowp.com" class="text-slate-600 hover:text-cyan-600 transition-colors">
                    hola@webtowp.com
                  </a>
                </div>
              </div>
            </div>

            <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300">
              <div class="flex items-start gap-4 group cursor-pointer">
                <div class="flex-shrink-0 w-14 h-14 bg-gradient-to-r from-purple-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg shadow-purple-500/30 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-purple-500 group-hover:to-purple-600 group-hover:bg-clip-text transition-all duration-300">
                    LinkedIn
                  </h3>
                  <a href="https://linkedin.com/company/webtowp" target="_blank" rel="noopener noreferrer" class="text-slate-600 hover:text-purple-600 transition-colors">
                    /company/webtowp
                  </a>
                </div>
              </div>
            </div>

            <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300">
              <div class="flex items-start gap-4 group cursor-pointer">
                <div class="flex-shrink-0 w-14 h-14 bg-gradient-to-r from-violet-500 to-violet-600 rounded-xl flex items-center justify-center shadow-lg shadow-violet-500/30 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-violet-500 group-hover:to-violet-600 group-hover:bg-clip-text transition-all duration-300">
                    Ubicación
                  </h3>
                  <p class="text-slate-600">
                    Remoto - Trabajamos con clientes en todo el mundo
                  </p>
                </div>
              </div>
            </div>

            <div class="bg-gradient-to-r from-purple-600 via-violet-500 to-cyan-500 rounded-2xl p-8 shadow-xl relative overflow-hidden">
              <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30"></div>
              
              <div class="relative z-10">
                <div class="flex items-center gap-3 mb-4">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                  <h3 class="text-2xl font-bold text-white">
                    Respuesta Rápida
                  </h3>
                </div>
                <p class="text-white/90 text-lg">
                  Respondemos todos los mensajes en menos de 24 horas. Tu proyecto es nuestra prioridad.
                </p>
              </div>
            </div>
          </div>

          <div>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </section>

    <section class="relative py-20 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-3xl p-12 md:p-16 shadow-xl">
          <div class="text-center max-w-3xl mx-auto">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">
              ¿Prefieres agendar una llamada?
            </h2>
            <p class="text-lg text-slate-600 mb-8">
              Agenda una videollamada de 30 minutos sin compromiso para discutir tu proyecto en detalle.
              Te mostraremos ejemplos y responderemos todas tus preguntas.
            </p>
            <a
              href="https://calendly.com/webtowp"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-gradient-to-r from-purple-600 via-violet-500 to-cyan-500 rounded-xl hover:opacity-90 transition-all shadow-lg hover:shadow-xl hover:scale-105"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              Agendar llamada
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="relative pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl p-8 text-center shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-2">
            <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-cyan-500 to-cyan-600 rounded-2xl flex items-center justify-center shadow-lg shadow-cyan-500/30">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">
              Respuesta en 24h
            </h3>
            <p class="text-slate-600">
              Garantizamos respuesta a tu consulta en menos de un día hábil.
            </p>
          </div>

          <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl p-8 text-center shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-2">
            <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center shadow-lg shadow-purple-500/30">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">
              Consulta Gratuita
            </h3>
            <p class="text-slate-600">
              Primera consulta sin costo para entender tu proyecto y necesidades.
            </p>
          </div>

          <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl p-8 text-center shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-2">
            <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-violet-500 to-violet-600 rounded-2xl flex items-center justify-center shadow-lg shadow-violet-500/30">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">
              Equipo Experto
            </h3>
            <p class="text-slate-600">
              Especialistas en WordPress Headless, Astro y desarrollo premium.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }
</style>
