---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmoothScroll from '../../components/SmoothScroll';
import FloatingOrbs from '../../components/FloatingOrbs';
import OptimizacionHero from '../../components/OptimizacionHero';
import OptimizacionProblem from '../../components/OptimizacionProblem';
import OptimizacionSolution from '../../components/OptimizacionSolution';
import OptimizacionProcess from '../../components/OptimizacionProcess';
import OptimizacionFAQ from '../../components/OptimizacionFAQ';
import OptimizacionBottomCTA from '../../components/OptimizacionBottomCTA';
---

<Layout 
  title="Optimización Técnica WordPress - WebToWP"
  description="Auditoría y optimización técnica profunda para tu sitio actual. Mejoramos tus métricas de velocidad para retener a tus usuarios y cumplir con las exigentes normativas de los motores de búsqueda."
>
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10">
    <OptimizacionHero client:load />
    <OptimizacionProblem client:visible />
    <OptimizacionSolution client:visible />
    <OptimizacionProcess client:visible />
    <OptimizacionFAQ client:visible />
    <OptimizacionBottomCTA client:visible />
  </main>

  <Footer />
</Layout>
