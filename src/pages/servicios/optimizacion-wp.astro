---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmoothScroll from '../../components/SmoothScroll';
import FloatingOrbs from '../../components/FloatingOrbs';
---

<Layout title="Optimización WordPress - WebToWP">
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10 min-h-screen pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <section class="text-center mb-20">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-brand-purple to-brand-cyan bg-clip-text text-transparent">
          Optimización WordPress Extrema
        </h1>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto mb-12">
          Transforma tu sitio WordPress lento en una máquina de velocidad. Mejora el rendimiento, SEO y experiencia de usuario.
        </p>
        <div class="relative w-full max-w-4xl mx-auto rounded-3xl overflow-hidden shadow-2xl">
          <img 
            src="/hero-optimization.webp" 
            alt="WordPress Optimization" 
            class="w-full h-auto"
            onerror="this.src='https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1200&h=600&fit=crop'"
          />
        </div>
      </section>

      <section class="mb-20">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl font-bold mb-8 text-slate-900">¿Por qué Optimizar tu WordPress?</h2>
          <div class="bg-white/60 backdrop-blur-lg rounded-3xl p-8 border border-white/40 shadow-xl">
            <p class="text-lg text-slate-700 leading-relaxed mb-4">
              Un sitio WordPress lento pierde visitantes, ventas y posicionamiento en Google. Cada segundo de demora 
              reduce las conversiones hasta un 7% y aumenta la tasa de rebote significativamente.
            </p>
            <p class="text-lg text-slate-700 leading-relaxed">
              Nuestra optimización integral mejora la velocidad de carga, reduce el consumo de recursos del servidor 
              y garantiza una experiencia fluida en todos los dispositivos. Resultados medibles y duraderos.
            </p>
          </div>
        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-4xl font-bold mb-12 text-center text-slate-900">Proceso de Optimización</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Auditoría Completa</h3>
            <p class="text-slate-600">
              Análisis profundo de velocidad, recursos, plugins, base de datos y configuración del servidor.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-purple to-violet-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Optimización de Imágenes</h3>
            <p class="text-slate-600">
              Compresión inteligente, lazy loading y formatos modernos (WebP) para reducir peso sin perder calidad.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Minificación de Código</h3>
            <p class="text-slate-600">
              Compresión de CSS, JavaScript y HTML para reducir el tamaño de archivos y peticiones HTTP.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-purple to-violet-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Caché Avanzado</h3>
            <p class="text-slate-600">
              Implementación de caché de página, objeto y navegador para servir contenido instantáneamente.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Limpieza de Base de Datos</h3>
            <p class="text-slate-600">
              Eliminación de revisiones, spam, transients y optimización de tablas para máxima eficiencia.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-purple to-violet-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">CDN Global</h3>
            <p class="text-slate-600">
              Configuración de red de distribución de contenido para servir archivos desde servidores cercanos al usuario.
            </p>
          </div>

        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-4xl font-bold mb-12 text-center text-slate-900">Resultados Garantizados</h2>
        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          
          <div class="bg-gradient-to-br from-brand-cyan/10 to-blue-500/10 rounded-2xl p-8 border border-brand-cyan/20">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-full flex items-center justify-center">
                <span class="text-3xl font-bold text-white">3x</span>
              </div>
              <h3 class="text-2xl font-bold text-slate-900">Velocidad Mejorada</h3>
            </div>
            <p class="text-slate-700 mb-4">
              Reducción del tiempo de carga en promedio del 70%. Sitios que cargaban en 6 segundos ahora lo hacen en menos de 2.
            </p>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>PageSpeed Score 90+</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>GTmetrix Grade A</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Core Web Vitals aprobados</span>
              </li>
            </ul>
          </div>

          <div class="bg-gradient-to-br from-brand-purple/10 to-violet-500/10 rounded-2xl p-8 border border-brand-purple/20">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-gradient-to-r from-brand-purple to-violet-500 rounded-full flex items-center justify-center">
                <span class="text-3xl font-bold text-white">50%</span>
              </div>
              <h3 class="text-2xl font-bold text-slate-900">Ahorro de Recursos</h3>
            </div>
            <p class="text-slate-700 mb-4">
              Reducción significativa en el uso de CPU, RAM y ancho de banda del servidor, permitiendo manejar más tráfico.
            </p>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Menor costo de hosting</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Capacidad para más visitantes</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Estabilidad mejorada</span>
              </li>
            </ul>
          </div>

          <div class="bg-gradient-to-br from-brand-cyan/10 to-blue-500/10 rounded-2xl p-8 border border-brand-cyan/20">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-full flex items-center justify-center">
                <span class="text-3xl font-bold text-white">↑</span>
              </div>
              <h3 class="text-2xl font-bold text-slate-900">Mejor SEO</h3>
            </div>
            <p class="text-slate-700 mb-4">
              Google prioriza sitios rápidos. La velocidad es un factor de ranking directo que mejora tu posicionamiento.
            </p>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Mejor ranking en Google</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Menor tasa de rebote</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Más tiempo en el sitio</span>
              </li>
            </ul>
          </div>

          <div class="bg-gradient-to-br from-brand-purple/10 to-violet-500/10 rounded-2xl p-8 border border-brand-purple/20">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-gradient-to-r from-brand-purple to-violet-500 rounded-full flex items-center justify-center">
                <span class="text-3xl font-bold text-white">+</span>
              </div>
              <h3 class="text-2xl font-bold text-slate-900">Más Conversiones</h3>
            </div>
            <p class="text-slate-700 mb-4">
              Sitios rápidos convierten mejor. Cada segundo ahorrado aumenta las ventas y leads generados.
            </p>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Mayor tasa de conversión</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Mejor experiencia de usuario</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>ROI comprobado</span>
              </li>
            </ul>
          </div>

        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-4xl font-bold mb-12 text-center text-slate-900">Paquetes de Optimización</h2>
        <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
          
          <div class="bg-white/60 backdrop-blur-lg rounded-3xl p-8 border border-white/40 shadow-lg hover:shadow-2xl transition-all duration-300">
            <div class="text-center mb-6">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Express</h3>
              <p class="text-slate-600 mb-4">Optimización básica</p>
              <div class="text-5xl font-bold text-slate-900 mb-2">$399</div>
              <p class="text-slate-500">USD - Pago único</p>
            </div>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Optimización de imágenes</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Caché básico</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Minificación CSS/JS</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Limpieza de BD básica</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Entrega en 48 horas</span>
              </li>
            </ul>
            <a href="#contacto" class="block w-full text-center py-3 px-6 bg-slate-900 text-white rounded-xl font-semibold hover:bg-slate-800 transition-colors">
              Comenzar
            </a>
          </div>

          <div class="bg-gradient-to-br from-brand-purple to-brand-cyan rounded-3xl p-[2px] shadow-2xl transform scale-105">
            <div class="bg-white/90 backdrop-blur-lg rounded-3xl p-8 h-full">
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-brand-purple to-brand-cyan text-white px-4 py-1 rounded-full text-sm font-bold">
                RECOMENDADO
              </div>
              <div class="text-center mb-6 mt-4">
                <h3 class="text-2xl font-bold text-slate-900 mb-2">Premium</h3>
                <p class="text-slate-600 mb-4">Optimización completa</p>
                <div class="text-5xl font-bold bg-gradient-to-r from-brand-purple to-brand-cyan bg-clip-text text-transparent mb-2">$799</div>
                <p class="text-slate-500">USD - Pago único</p>
              </div>
              <ul class="space-y-4 mb-8">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-brand-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                  </svg>
                  <span class="text-slate-700 font-medium">Todo del plan Express +</span>
                </li>
