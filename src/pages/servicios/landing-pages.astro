---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmoothScroll from '../../components/SmoothScroll';
import FloatingOrbs from '../../components/FloatingOrbs';
import LandingHero from '../../components/LandingHero';
import LandingProblem from '../../components/LandingProblem';
import LandingSolution from '../../components/LandingSolution';
import LandingProcess from '../../components/LandingProcess';
import LandingFAQ from '../../components/LandingFAQ';
import LandingBottomCTA from '../../components/LandingBottomCTA';
---

<Layout 
  title="Landing Pages Rápidas Diseñadas para Convertir - WebToWP"
  description="Maximiza el retorno de tus campañas publicitarias con Landing Pages optimizadas. Construcción rápida, integraciones directas a tu CRM y tiempos de carga instantáneos."
>
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10">
    <LandingHero client:load />
    <LandingProblem client:visible />
    <LandingSolution client:visible />
    <LandingProcess client:visible />
    <LandingFAQ client:visible />
    <LandingBottomCTA client:visible />
  </main>

  <Footer />
</Layout>
