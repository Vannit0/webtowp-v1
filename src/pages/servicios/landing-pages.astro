---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmoothScroll from '../../components/SmoothScroll';
import FloatingOrbs from '../../components/FloatingOrbs';
---

<Layout title="Landing Pages - WebToWP">
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10 min-h-screen pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <section class="text-center mb-20">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-brand-purple to-brand-cyan bg-clip-text text-transparent">
          Landing Pages de Alto Impacto
        </h1>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto mb-12">
          Convierte visitantes en clientes con páginas diseñadas para maximizar conversiones y generar resultados medibles.
        </p>
        <div class="relative w-full max-w-4xl mx-auto rounded-3xl overflow-hidden shadow-2xl">
          <img 
            src="/hero-landing.webp" 
            alt="Landing Page Example" 
            class="w-full h-auto"
            onerror="this.src='https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=1200&h=600&fit=crop'"
          />
        </div>
      </section>

      <section class="mb-20">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl font-bold mb-8 text-slate-900">¿Qué es una Landing Page?</h2>
          <div class="bg-white/60 backdrop-blur-lg rounded-3xl p-8 border border-white/40 shadow-xl">
            <p class="text-lg text-slate-700 leading-relaxed mb-4">
              Una Landing Page es una página web diseñada con un único objetivo: convertir visitantes en leads o clientes. 
              A diferencia de un sitio web tradicional, elimina distracciones y guía al usuario hacia una acción específica.
            </p>
            <p class="text-lg text-slate-700 leading-relaxed">
              Perfecta para campañas de marketing, lanzamientos de productos, captación de emails o promociones especiales. 
              Cada elemento está optimizado para maximizar la tasa de conversión.
            </p>
          </div>
        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-4xl font-bold mb-12 text-center text-slate-900">Beneficios Clave</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Alta Conversión</h3>
            <p class="text-slate-600">
              Diseño enfocado en una sola acción, eliminando distracciones y maximizando resultados.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-purple to-violet-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Rápida Implementación</h3>
            <p class="text-slate-600">
              Lanzamiento en días, no semanas. Ideal para campañas con plazos ajustados.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Métricas Claras</h3>
            <p class="text-slate-600">
              Seguimiento preciso de conversiones, clics y comportamiento del usuario.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-purple to-violet-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">SEO Optimizado</h3>
            <p class="text-slate-600">
              Estructura técnica perfecta para posicionamiento en buscadores y anuncios.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Mobile First</h3>
            <p class="text-slate-600">
              Diseño responsive que se adapta perfectamente a cualquier dispositivo.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-purple to-violet-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Carga Ultrarrápida</h3>
            <p class="text-slate-600">
              Optimización extrema para velocidades de carga menores a 2 segundos.
            </p>
          </div>

        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-4xl font-bold mb-12 text-center text-slate-900">Casos de Uso Ideales</h2>
        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          
          <div class="bg-gradient-to-br from-brand-cyan/10 to-blue-500/10 rounded-2xl p-8 border border-brand-cyan/20">
            <h3 class="text-2xl font-bold mb-4 text-slate-900">Lanzamiento de Productos</h3>
            <p class="text-slate-700 mb-4">
              Presenta tu nuevo producto o servicio con una página dedicada que destaque sus beneficios únicos y genere expectativa.
            </p>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Pre-lanzamientos y early access</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Captación de lista de espera</span>
              </li>
            </ul>
          </div>

          <div class="bg-gradient-to-br from-brand-purple/10 to-violet-500/10 rounded-2xl p-8 border border-brand-purple/20">
            <h3 class="text-2xl font-bold mb-4 text-slate-900">Campañas Publicitarias</h3>
            <p class="text-slate-700 mb-4">
              Maximiza el ROI de tus anuncios en Google, Facebook o Instagram con páginas de destino optimizadas.
            </p>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Google Ads y Facebook Ads</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>A/B testing de mensajes</span>
              </li>
            </ul>
          </div>

          <div class="bg-gradient-to-br from-brand-cyan/10 to-blue-500/10 rounded-2xl p-8 border border-brand-cyan/20">
            <h3 class="text-2xl font-bold mb-4 text-slate-900">Generación de Leads</h3>
            <p class="text-slate-700 mb-4">
              Captura información de contacto valiosa ofreciendo recursos gratuitos, demos o consultas.
            </p>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Ebooks y whitepapers</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Webinars y eventos online</span>
              </li>
            </ul>
          </div>

          <div class="bg-gradient-to-br from-brand-purple/10 to-violet-500/10 rounded-2xl p-8 border border-brand-purple/20">
            <h3 class="text-2xl font-bold mb-4 text-slate-900">Eventos y Promociones</h3>
            <p class="text-slate-700 mb-4">
              Crea urgencia y exclusividad para ofertas por tiempo limitado o eventos especiales.
            </p>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Black Friday y ofertas flash</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span>Registro a conferencias</span>
              </li>
            </ul>
          </div>

        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-4xl font-bold mb-12 text-center text-slate-900">Planes y Precios</h2>
        <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
          
          <div class="bg-white/60 backdrop-blur-lg rounded-3xl p-8 border border-white/40 shadow-lg hover:shadow-2xl transition-all duration-300">
            <div class="text-center mb-6">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Básico</h3>
              <p class="text-slate-600 mb-4">Ideal para comenzar</p>
              <div class="text-5xl font-bold text-slate-900 mb-2">$499</div>
              <p class="text-slate-500">USD - Pago único</p>
            </div>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Diseño responsive profesional</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Hasta 3 secciones</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Formulario de contacto</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-slate-700">SEO básico</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Entrega en 5 días</span>
              </li>
            </ul>
            <a href="#contacto" class="block w-full text-center py-3 px-6 bg-slate-900 text-white rounded-xl font-semibold hover:bg-slate-800 transition-colors">
              Comenzar
            </a>
          </div>

          <div class="bg-gradient-to-br from-brand-purple to-brand-cyan rounded-3xl p-[2px] shadow-2xl transform scale-105">
            <div class="bg-white/90 backdrop-blur-lg rounded-3xl p-8 h-full">
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-brand-purple to-brand-cyan text-white px-4 py-1 rounded-full text-sm font-bold">
                MÁS POPULAR
              </div>
              <div class="text-center mb-6 mt-4">
                <h3 class="text-2xl font-bold text-slate-900 mb-2">Profesional</h3>
                <p class="text-slate-600 mb-4">Para negocios serios</p>
                <div class="text-5xl font-bold bg-gradient-to-r from-brand-purple to-brand-cyan bg-clip-text text-transparent mb-2">$999</div>
                <p class="text-slate-500">USD - Pago único</p>
              </div>
              <ul class="space-y-4 mb-8">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-brand-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-slate-700 font-medium">Todo del plan Básico +</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-brand-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-slate-700">Hasta 6 secciones personalizadas</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-brand-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-slate-700">Integración con CRM/Email</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-brand-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-slate-700">Google Analytics + Pixel FB</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-brand-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-slate-700">SEO avanzado</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-brand-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-slate-700">Entrega en 3 días</span>
                </li>
              </ul>
              <a href="#contacto" class="block w-full text-center py-3 px-6 bg-gradient-to-r from-brand-purple to-brand-cyan text-white rounded-xl font-semibold hover:opacity-90 transition-opacity">
                Elegir Plan
              </a>
            </div>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-3xl p-8 border border-white/40 shadow-lg hover:shadow-2xl transition-all duration-300">
            <div class="text-center mb-6">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Enterprise</h3>
              <p class="text-slate-600 mb-4">Solución completa</p>
              <div class="text-5xl font-bold text-slate-900 mb-2">$1,999</div>
              <p class="text-slate-500">USD - Pago único</p>
            </div>
            <ul class="space-y-4 mb-8">
