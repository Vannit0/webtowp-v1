---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmoothScroll from '../../components/SmoothScroll';
import FloatingOrbs from '../../components/FloatingOrbs';
import HeadlessHero from '../../components/HeadlessHero';
import HeadlessProblem from '../../components/HeadlessProblem';
import HeadlessSolution from '../../components/HeadlessSolution';
import HeadlessProcess from '../../components/HeadlessProcess';
import HeadlessFAQ from '../../components/HeadlessFAQ';
import HeadlessBottomCTA from '../../components/HeadlessBottomCTA';
---

<Layout 
  title="Migración Headless WordPress - WebToWP"
  description="Transforma tu WordPress lento en una plataforma de alto rendimiento. Mantén la facilidad de publicar en WordPress, pero elimina sus problemas de velocidad y seguridad."
>
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10">
    <HeadlessHero client:load />
    <HeadlessProblem client:visible />
    <HeadlessSolution client:visible />
    <HeadlessProcess client:visible />
    <HeadlessFAQ client:visible />
    <HeadlessBottomCTA client:visible />
  </main>

  <Footer />
</Layout>
