---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmoothScroll from '../../components/SmoothScroll';
import FloatingOrbs from '../../components/FloatingOrbs';
import CorporateHero from '../../components/CorporateHero';
import CorporateProblem from '../../components/CorporateProblem';
import CorporateSolution from '../../components/CorporateSolution';
import CorporateProcess from '../../components/CorporateProcess';
import CorporateFAQ from '../../components/CorporateFAQ';
import CorporateBottomCTA from '../../components/CorporateBottomCTA';
---

<Layout 
  title="Sitios Web Corporativos Premium - WebToWP"
  description="Diseñamos y desarrollamos sitios informativos a medida. Seguros, ultra rápidos y muy fáciles de administrar para que tu presencia digital esté a la altura de tus servicios."
>
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10">
    <CorporateHero client:load />
    <CorporateProblem client:visible />
    <CorporateSolution client:visible />
    <CorporateProcess client:visible />
    <CorporateFAQ client:visible />
    <CorporateBottomCTA client:visible />
  </main>

  <Footer />
</Layout>
