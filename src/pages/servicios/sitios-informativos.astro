---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmoothScroll from '../../components/SmoothScroll';
import FloatingOrbs from '../../components/FloatingOrbs';
---

<Layout title="Sitios Informativos - WebToWP">
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10 min-h-screen pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <section class="text-center mb-20">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-brand-purple to-brand-cyan bg-clip-text text-transparent">
          Sitios Informativos Profesionales
        </h1>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto mb-12">
          Sitios corporativos y portafolios con gestión de contenido flexible, rendimiento excepcional y diseño que refleja tu marca.
        </p>
        <div class="relative w-full max-w-4xl mx-auto rounded-3xl overflow-hidden shadow-2xl">
          <img 
            src="/hero-sitios.webp" 
            alt="Sitios Informativos Example" 
            class="w-full h-auto"
            onerror="this.src='https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1200&h=600&fit=crop'"
          />
        </div>
      </section>

      <section class="mb-20">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl font-bold mb-8 text-slate-900">¿Qué es un Sitio Informativo?</h2>
          <div class="bg-white/60 backdrop-blur-lg rounded-3xl p-8 border border-white/40 shadow-xl">
            <p class="text-lg text-slate-700 leading-relaxed mb-4">
              Un sitio informativo es la presencia digital profesional de tu empresa. Diseñado para comunicar quién eres, 
              qué haces y por qué eres la mejor opción, con una estructura clara y navegación intuitiva.
            </p>
            <p class="text-lg text-slate-700 leading-relaxed">
              Ideal para empresas, profesionales independientes, portafolios creativos y organizaciones que necesitan 
              una plataforma robusta para compartir información, noticias y contenido actualizado.
            </p>
          </div>
        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-4xl font-bold mb-12 text-center text-slate-900">Características Principales</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-purple to-violet-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">CMS WordPress</h3>
            <p class="text-slate-600">
              Gestión de contenido intuitiva que te permite actualizar textos, imágenes y páginas sin conocimientos técnicos.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Diseño Personalizado</h3>
            <p class="text-slate-600">
              Diseño único que refleja tu identidad de marca, no plantillas genéricas.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-purple to-violet-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Responsive Design</h3>
            <p class="text-slate-600">
              Adaptación perfecta a móviles, tablets y escritorio para una experiencia óptima en cualquier dispositivo.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">SEO Avanzado</h3>
            <p class="text-slate-600">
              Optimización técnica completa para posicionamiento en Google y otros buscadores.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-purple to-violet-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Formularios Inteligentes</h3>
            <p class="text-slate-600">
              Formularios de contacto, cotización y suscripción con protección anti-spam.
            </p>
          </div>

          <div class="bg-white/60 backdrop-blur-lg rounded-2xl p-6 border border-white/40 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-12 h-12 bg-gradient-to-r from-brand-cyan to-blue-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">Seguridad Reforzada</h3>
            <p class="text-slate-600">
              Certificado SSL, backups automáticos y protección contra ataques maliciosos.
            </p>
          </div>

        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-4xl font-bold mb-12 text-center text-slate-900">Tipos de Sitios que Desarrollamos</h2>
        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          
          <div class="bg-gradient-to-br from-brand-purple/10 to-violet-500/10 rounded-2xl p-8 border border-brand-purple/20">
            <h3 class="text-2xl font-bold mb-4 text-slate-900">Sitios Corporativos</h3>
            <p class="text-slate-700 mb-4">
              Presencia profesional para empresas B2B y B2C con secciones de servicios, equipo, valores y casos de éxito.
            </p>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Página de inicio impactante</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-purple mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
