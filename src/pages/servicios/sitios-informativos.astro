              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span class="text-slate-700">Entrega en 10 días</span>
              </li>
            </ul>
            <a href="#contacto" class="block w-full text-center py-3 px-6 bg-slate-900 text-white rounded-xl font-semibold hover:bg-slate-800 transition-colors">
              Comenzar
            </a>
          </div>

          <div class="bg-gradient-to-br from-brand-purple to-brand-cyan rounded-3xl p-[2px] shadow-2xl transform scale-105">
            <div class="bg-white/90 backdrop-blur-lg rounded-3xl p-8 h-full">
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-brand-purple to-brand-cyan text-white px-4 py-1 rounded-full text-sm font-bold">
                MÁS POPULAR
              </div>
              <div class="text-center mb-6 mt-4">
                <h3 class="text-2xl font-bold text-slate-900 mb-2">Profesional</h3>
                <p class="text-slate-600 mb-4">Completo y escalable</p>
                <div class="text-5xl font-bold bg-gradient-to-r from-brand-purple to-brand-cyan bg-clip-text text-transparent mb-2">$2,499</div>
