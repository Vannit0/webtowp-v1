                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Newsletter integrado</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-brand-cyan mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
                <span>Comentarios y engagement</span>
              </li>
            </ul>
          </div>

        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-4xl font-bold mb-12 text-center text-slate-900">Planes de Desarrollo</h2>
        <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
          
          <div class="bg-white/60 backdrop-blur-lg rounded-3xl p-8 border border-white/40 shadow-lg hover:shadow-2xl transition-all duration-300">
            <div class="text-center mb-6">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Esencial</h3>
              <p class="text-slate-600 mb-4">Para comenzar tu presencia</p>
              <div class="text-5xl font-bold text-slate-900 mb-2">$1,299</div>
              <p class="text-slate-500">USD - Pago único</p>
            </div>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-cyan flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"></path>
                </svg>
