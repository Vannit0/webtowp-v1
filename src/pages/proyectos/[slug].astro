---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmoothScroll from '../../components/SmoothScroll';
import FloatingOrbs from '../../components/FloatingOrbs';
import { getProjects, getProjectBySlug } from '../../lib/api.js';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getProjects();
  
  return projects.map((project: any) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props as any;

if (!project) {
  return Astro.redirect('/proyectos');
}
---

<Layout 
  title={`${project.title} - Caso de Estudio | WebToWP`}
  description={project.excerpt.replace(/<[^>]*>/g, '').substring(0, 160)}
>
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10 min-h-screen">
    <section class="relative overflow-hidden pt-32 pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
          <div>
            <a 
              href="/proyectos" 
              class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 mb-6 transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
              Volver a proyectos
            </a>

            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 backdrop-blur-xl border border-white/60 shadow-lg shadow-slate-200/50 text-slate-700 text-sm font-medium mb-6">
              <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>Caso de Estudio</span>
            </div>

            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
              <span class="bg-gradient-to-r from-cyan-500 via-purple-500 to-violet-600 bg-clip-text text-transparent">
                {project.title}
              </span>
            </h1>

            <div 
              class="text-lg text-slate-600 mb-8 leading-relaxed"
              set:html={project.excerpt}
            />

            {project.technologies && project.technologies.length > 0 && (
              <div class="mb-8">
                <h3 class="text-sm font-semibold text-slate-600 mb-3 uppercase tracking-wide">
                  Tecnologías Utilizadas
                </h3>
                <div class="flex flex-wrap gap-3">
                  {project.technologies.map((tech: string) => (
                    <span class="group px-4 py-2 text-sm font-semibold bg-white/40 backdrop-blur-xl text-brand-purple rounded-full border border-white/50 shadow-md hover:shadow-lg hover:bg-white/60 hover:text-brand-cyan hover:border-brand-cyan/30 transition-all duration-300 cursor-default">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>

          <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-r from-purple-500/20 to-cyan-500/20 rounded-3xl blur-2xl"></div>
            <div class="relative bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl overflow-hidden shadow-2xl transform hover:scale-105 transition-transform duration-500">
              <img
                src={project.imageUrl}
                alt={project.alt}
                class="w-full h-auto"
                loading="eager"
              />
            </div>
            <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-[90%] h-8 bg-gradient-to-b from-purple-400/40 to-transparent blur-xl rounded-full"></div>
          </div>
        </div>

        <div class="mb-20">
          <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-3xl p-8 md:p-12 shadow-xl">
            <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-8 text-center">
              Métricas de Éxito
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-cyan-500 to-cyan-600 rounded-2xl flex items-center justify-center shadow-lg shadow-cyan-500/30">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <div class="text-3xl font-bold bg-gradient-to-r from-cyan-500 to-cyan-600 bg-clip-text text-transparent mb-2">
                  {project.loadTime}
                </div>
                <div class="text-slate-600 font-medium">
                  Tiempo de Carga
                </div>
              </div>

              <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center shadow-lg shadow-purple-500/30">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                </div>
                <div class="text-3xl font-bold bg-gradient-to-r from-purple-500 to-purple-600 bg-clip-text text-transparent mb-2">
                  {project.seoScore}%
                </div>
                <div class="text-slate-600 font-medium">
                  SEO Score
                </div>
              </div>

              <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-violet-500 to-violet-600 rounded-2xl flex items-center justify-center shadow-lg shadow-violet-500/30">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                  </svg>
                </div>
                <div class="text-3xl font-bold bg-gradient-to-r from-violet-500 to-violet-600 bg-clip-text text-transparent mb-2">
                  100%
                </div>
                <div class="text-slate-600 font-medium">
                  Seguridad Total
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
          <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl p-8 shadow-lg">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 bg-gradient-to-r from-red-500 to-orange-500 rounded-xl flex items-center justify-center shadow-lg shadow-red-500/30">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-900">
                El Reto
              </h3>
            </div>
            {project.challenge ? (
              <div 
                class="text-slate-600 leading-relaxed prose prose-slate max-w-none"
                set:html={project.challenge}
              />
            ) : (
              <p class="text-slate-600 leading-relaxed">
                El cliente necesitaba una solución web moderna que pudiera escalar con su negocio,
                ofreciendo velocidad excepcional y una experiencia de usuario premium sin comprometer
                la facilidad de gestión de contenido.
              </p>
            )}
          </div>

          <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl p-8 shadow-lg">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 bg-gradient-to-r from-cyan-500 to-purple-500 rounded-xl flex items-center justify-center shadow-lg shadow-cyan-500/30">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-900">
                La Solución WebToWP
              </h3>
            </div>
            {project.solution ? (
              <div 
                class="text-slate-600 leading-relaxed prose prose-slate max-w-none"
                set:html={project.solution}
              />
            ) : (
              <p class="text-slate-600 leading-relaxed">
                Implementamos una arquitectura headless con WordPress como CMS y Astro como frontend.
                Esta combinación ofrece la potencia de WordPress para gestión de contenido con la
                velocidad ultrarrápida de Astro, resultando en un sitio que carga en milisegundos
                y ofrece una experiencia de usuario excepcional.
              </p>
            )}
          </div>
        </div>

        {project.content && (
          <div class="mb-20">
            <div class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-2xl p-8 md:p-12 shadow-lg">
              <div 
                class="prose prose-slate prose-lg max-w-none"
                set:html={project.content}
              />
            </div>
          </div>
        )}

        <div class="relative bg-gradient-to-r from-purple-600 via-violet-500 to-cyan-500 rounded-3xl p-12 md:p-16 overflow-hidden">
          <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30"></div>
          
          <div class="relative z-10 text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
              ¿Quieres resultados similares?
            </h2>
            <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
              Descubre cómo podemos transformar tu presencia digital con la misma tecnología
              de vanguardia que usamos en {project.title}.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              {project.url && project.url !== '#' && (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-purple-600 bg-white rounded-xl hover:bg-gray-50 transition-all shadow-lg hover:shadow-xl hover:scale-105"
                >
                  Visitar sitio en vivo
                  <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                </a>
              )}
              <a
                href="/contacto"
                class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-white/20 backdrop-blur-xl border-2 border-white/50 rounded-xl hover:bg-white/30 transition-all"
              >
                Comenzar mi proyecto
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .prose {
    color: rgb(71 85 105);
  }
  
  .prose h2 {
    color: rgb(15 23 42);
    font-weight: 700;
    margin-top: 2em;
    margin-bottom: 1em;
  }
  
  .prose h3 {
    color: rgb(30 41 59);
    font-weight: 600;
    margin-top: 1.6em;
    margin-bottom: 0.6em;
  }
  
  .prose p {
    margin-bottom: 1.25em;
  }
  
  .prose a {
    color: rgb(124 58 237);
    text-decoration: underline;
  }
  
  .prose a:hover {
    color: rgb(109 40 217);
  }
  
  .prose ul, .prose ol {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    padding-left: 1.625em;
  }
  
  .prose li {
    margin-top: 0.5em;
    margin-bottom: 0.5em;
  }
</style>
