---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmoothScroll from '../../components/SmoothScroll';
import FloatingOrbs from '../../components/FloatingOrbs';
import AuthorBox from '../../components/AuthorBox.astro';
import { getAllPosts, getPostBySlug } from '../../lib/api';
import type { Post, Category } from '../../lib/types';
import { cleanExcerpt } from '../../lib/utils';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  
  return posts.map((post: Post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props as Props;

function formatDate(dateString: string) {
  const date = new Date(dateString);
  return date.toLocaleDateString('es-ES', { 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
  });
}

const readingTime = Math.ceil(post.content.replace(/<[^>]*>/g, '').split(/\s+/).length / 200);
---

<Layout 
  title={`${post.title} | Blog WebToWP`}
  description={post.excerpt.replace(/<[^>]*>/g, '').substring(0, 160)}
>
  <FloatingOrbs client:load />
  <SmoothScroll client:load />
  <Navbar />
  
  <main class="relative z-10 min-h-screen">
    <article class="pt-32 pb-20 px-6">
      <div class="max-w-4xl mx-auto">
        <header class="mb-12">
          <div class="flex flex-wrap gap-2 mb-6">
            {post.categories.map((category: Category) => (
              <span class="text-sm font-semibold px-4 py-2 rounded-full bg-gradient-to-r from-brand-cyan/20 to-brand-purple/20 text-brand-purple border border-brand-purple/30">
                {category.name}
              </span>
            ))}
          </div>
          
          <h1 class="text-4xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-brand-cyan via-brand-purple to-brand-violet bg-clip-text text-transparent leading-tight">
            {post.title}
          </h1>
          
          <div class="flex flex-wrap items-center gap-6 text-gray-600 mb-8">
            <div class="flex items-center gap-3">
              {post.author.avatar && (
                <img 
                  src={post.author.avatar} 
                  alt={post.author.name}
                  class="w-12 h-12 rounded-full border-2 border-brand-purple/30"
                  loading="eager"
                />
              )}
              <div>
                <p class="font-semibold text-gray-900">{post.author.name}</p>
                <time class="text-sm text-gray-500" datetime={post.date}>
                  {formatDate(post.date)}
                </time>
              </div>
            </div>
            
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-brand-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="text-sm">{readingTime} min de lectura</span>
            </div>
          </div>
          
          <p class="text-xl text-gray-700 leading-relaxed mb-8 p-6 bg-white/40 backdrop-blur-xl rounded-2xl border border-white/50">
            {cleanExcerpt(post.excerpt)}
          </p>
        </header>

        <div class="relative mb-12 rounded-3xl overflow-hidden shadow-2xl">
          <img
            src={post.imageUrl}
            alt={post.alt}
            class="w-full h-auto"
            loading="eager"
          />
        </div>

        <div class="prose prose-lg max-w-none">
          <div 
            class="blog-content text-gray-800 leading-relaxed"
            set:html={post.content}
          />
        </div>

        <AuthorBox 
          authorName={post.author.name}
          authorAvatar={post.author.avatar}
          authorDescription={post.author.description}
        />

        <div class="mt-16 pt-8 border-t border-gray-300">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div class="flex items-center gap-3">
              {post.author.avatar && (
                <img 
                  src={post.author.avatar} 
                  alt={post.author.name}
                  class="w-16 h-16 rounded-full border-2 border-brand-purple/30"
                  loading="lazy"
                />
              )}
              <div>
                <p class="text-sm text-gray-500">Escrito por</p>
                <p class="font-bold text-xl text-gray-900">{post.author.name}</p>
              </div>
            </div>
            
            <a 
              href="/blog" 
              class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-brand-cyan to-brand-purple text-white font-semibold rounded-full hover:shadow-lg hover:scale-105 transition-all duration-300"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
              </svg>
              Volver al Blog
            </a>
          </div>
        </div>
      </div>
    </article>
  </main>
  
  <Footer />
</Layout>

<style>
  .blog-content :global(> *) {
    margin-bottom: 1.5rem;
  }

  .blog-content :global(h2) {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    background: linear-gradient(to right, var(--color-brand-cyan), var(--color-brand-purple));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .blog-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: rgb(17 24 39);
  }

  .blog-content :global(h4) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: rgb(31 41 55);
  }

  .blog-content :global(p) {
    font-size: 1.125rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
    color: rgb(55 65 81);
  }

  .blog-content :global(a) {
    color: var(--color-brand-purple);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: rgba(147, 51, 234, 0.3);
    transition: color 0.3s;
  }

  .blog-content :global(a:hover) {
    color: var(--color-brand-cyan);
    text-decoration-color: rgba(6, 182, 212, 0.5);
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .blog-content :global(ul li),
  .blog-content :global(ol li) {
    margin-bottom: 0.5rem;
  }

  .blog-content :global(ul) {
    list-style-type: disc;
  }

  .blog-content :global(ol) {
    list-style-type: decimal;
  }

  .blog-content :global(li) {
    font-size: 1.125rem;
    color: rgb(55 65 81);
    line-height: 1.75;
  }

  .blog-content :global(blockquote) {
    border-left: 4px solid var(--color-brand-purple);
    padding-left: 1.5rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
    margin-top: 2rem;
    margin-bottom: 2rem;
    font-style: italic;
    color: rgb(55 65 81);
    background-color: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(24px);
    border-radius: 0 1rem 1rem 0;
  }

  .blog-content :global(code) {
    background-color: rgb(243 244 246);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: ui-monospace, monospace;
    color: var(--color-brand-purple);
  }

  .blog-content :global(pre) {
    background-color: rgb(17 24 39);
    color: rgb(243 244 246);
    padding: 1.5rem;
    border-radius: 1rem;
    overflow-x: auto;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  .blog-content :global(pre code) {
    background-color: transparent;
    color: rgb(243 244 246);
    padding: 0;
  }

  .blog-content :global(img) {
    border-radius: 1rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    margin-top: 2rem;
    margin-bottom: 2rem;
    width: 100%;
    height: auto;
  }

  .blog-content :global(table) {
    width: 100%;
    margin-top: 2rem;
    margin-bottom: 2rem;
    border-collapse: collapse;
  }

  .blog-content :global(th) {
    background: linear-gradient(to right, rgba(6, 182, 212, 0.2), rgba(147, 51, 234, 0.2));
    color: rgb(17 24 39);
    font-weight: 700;
    padding: 1rem;
    text-align: left;
    border: 1px solid rgb(209 213 219);
  }

  .blog-content :global(td) {
    padding: 1rem;
    border: 1px solid rgb(209 213 219);
    color: rgb(55 65 81);
  }

  .blog-content :global(strong) {
    font-weight: 700;
    color: rgb(17 24 39);
  }

  .blog-content :global(em) {
    font-style: italic;
  }

  .blog-content :global(hr) {
    margin-top: 3rem;
    margin-bottom: 3rem;
    border-top: 2px solid rgb(209 213 219);
  }
</style>
